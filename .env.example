# git-assist environment — copy to .env and fill in real values
# When running via `docker compose up`, use the URLs below (services talk over Docker network).
# When running locally (outside Docker), use localhost URLs shown in comments.

# --- Stores ---
# Qdrant vector DB (port 6333)
GIT_ASSIST_VECTOR_URL=qdrant://qdrant:6333          # docker-compose: qdrant://qdrant:6333
                                                     # local:         qdrant://localhost:6333

# Neo4j graph DB (bolt port 7687) — credentials must match NEO4J_AUTH below
GIT_ASSIST_GRAPH_URL=neo4j://neo4j:7687             # docker-compose: neo4j://neo4j:7687
                                                     # local:         neo4j://localhost:7687
GIT_ASSIST_GRAPH_USER=neo4j
GIT_ASSIST_GRAPH_PASSWORD=gitassist

# Postgres meta store (port 5432) — fill in POSTGRES_* vars below first
GIT_ASSIST_META_URL=postgresql://gitassist:gitassist@postgres:5432/gitassist
                                                     # local: postgresql://gitassist:gitassist@localhost:5432/gitassist

# --- Embedder (Ollama, port 11434) ---
GIT_ASSIST_EMBED_URL=ollama://ollama:11434          # docker-compose: ollama://ollama:11434
                                                     # local:         ollama://localhost:11434
GIT_ASSIST_EMBED_MODEL=qwen3-embedding:4b
GIT_ASSIST_EMBED_DIM=1024

# --- Reranker (Ollama, port 11434) ---
# Qwen3-Reranker-0.6B: a decoder-only, logit-scoring model served via Ollama's
# /api/generate + logprobs (see rerank.py).
GIT_ASSIST_RERANK_URL=ollama://ollama:11434         # docker-compose: ollama://ollama:11434
                                                     # local:         ollama://localhost:11434
GIT_ASSIST_RERANK_MODEL=hf.co/QuantFactory/Qwen3-Reranker-0.6B-GGUF:Q4_K_M

# --- Generation (Ollama, port 11434) ---
GIT_ASSIST_GEN_URL=ollama://ollama:11434            # docker-compose: ollama://ollama:11434
                                                     # local:         ollama://localhost:11434
GIT_ASSIST_GEN_MODEL=qwen3:4b

# --- HyDE query expansion (Ollama) ---
GIT_ASSIST_HYDE_URL=ollama://ollama:11434
GIT_ASSIST_HYDE_MODEL=qwen3:4b

# --- Chunking ---
GIT_ASSIST_CHUNK_SIZE=1000
GIT_ASSIST_CHUNK_OVERLAP=100

# --- GitLab push webhook (spec 24) ---
# Worker validates the X-Gitlab-Token header against this; must match GITLAB_WEBHOOK_SECRET below.
GIT_ASSIST_WEBHOOK_SECRET=change-me
# Token injected into the clone URL for private repos ("" = no auth / public repo).
GIT_ASSIST_GITLAB_CLONE_TOKEN=

# --- Docker Compose service credentials ---
POSTGRES_USER=gitassist
POSTGRES_PASSWORD=gitassist
POSTGRES_DB=gitassist
NEO4J_AUTH=neo4j/gitassist                          # format: username/password

# --- GitLab CE (spec 24) ---
GITLAB_ROOT_PASSWORD=changeme123!                   # GitLab root password (min 8 chars)
GITLAB_PROJECT_NAME=git-assist-repo                 # project created by gitlab-setup
GITLAB_WEBHOOK_SECRET=change-me                     # shared secret; must match GIT_ASSIST_WEBHOOK_SECRET
